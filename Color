import sys, cv2, numpy as np
import os, serial, serial.tools.list_ports
from datetime import datetime
from PyQt5 import QtWidgets, QtGui, QtCore
from ultralytics import YOLO 

# ================= SETTINGS =================
DELTA_E_THRESHOLD = 15.0  
CLASS_MAP = {0: "ROI", 1: "COLOR", 2: "DECO"} 

def extract_advanced_pigment(roi):
    if roi is None or roi.size < 50: return None
    h, w = roi.shape[:2]
    # 20% Crop to remove black borders
    roi_cropped = roi[int(h*0.2):int(h*0.8), int(w*0.2):int(w*0.8)]
    if roi_cropped.size == 0: roi_cropped = roi
    
    hsv = cv2.cvtColor(roi_cropped, cv2.COLOR_BGR2HSV)
    h, s, v = cv2.split(hsv)
    v_norm = np.full_like(v, 128) # Intensity Normalization
    hsv_norm = cv2.merge([h, s, v_norm])
    
    bgr_norm = cv2.cvtColor(hsv_norm, cv2.COLOR_HSV2BGR)
    lab_norm = cv2.cvtColor(bgr_norm, cv2.COLOR_BGR2LAB)
    return np.median(lab_norm.reshape(-1, 3), axis=0)

class VideoThread(QtCore.QThread):
    change_pixmap_signal = QtCore.pyqtSignal(np.ndarray)
    def __init__(self):
        super().__init__()
        self._run_flag = True
        self.current_frame = None

    def run(self):
        cap = cv2.VideoCapture(0)
        while self._run_flag:
            ret, cv_img = cap.read()
            if ret:
                self.current_frame = cv_img
                self.change_pixmap_signal.emit(cv_img)
        cap.release()

    def stop(self):
        self._run_flag = False
        self.wait()

class DecoInspectionSystem(QtWidgets.QMainWindow):
    def __init__(self):
        super().__init__()
        self.setWindowTitle("DECO Color Inspection — SPEN Compact")
        self.setFixedSize(1300, 850)
        self.dataset_path = ""
        self.model = None
        self.thread = None
        self.build_ui()

    def build_ui(self):
        central = QtWidgets.QWidget()
        self.setCentralWidget(central)
        main_layout = QtWidgets.QHBoxLayout(central)

        # LEFT PANEL
        left_layout = QtWidgets.QVBoxLayout()
        self.screen = QtWidgets.QLabel()
        self.screen.setStyleSheet("background:black; border:3px solid #111;")
        self.screen.setAlignment(QtCore.Qt.AlignCenter)
        left_layout.addWidget(self.screen, 5)

        self.status_banner = QtWidgets.QLabel("WAITING")
        self.status_banner.setFixedHeight(80)
        self.status_banner.setAlignment(QtCore.Qt.AlignCenter)
        self.status_banner.setStyleSheet("font-size:38px; font-weight:bold; border:4px solid black; background:white;")
        left_layout.addWidget(self.status_banner)

        self.log_table = QtWidgets.QTableWidget(0, 4)
        self.log_table.setHorizontalHeaderLabels(["#", "Time", "Result", "ΔE"])
        self.log_table.horizontalHeader().setSectionResizeMode(QtWidgets.QHeaderView.Stretch)
        self.log_table.setFixedHeight(180)
        left_layout.addWidget(self.log_table)
        main_layout.addLayout(left_layout, 4)

        # RIGHT PANEL
        right_panel = QtWidgets.QVBoxLayout()
        right_panel.addWidget(QtWidgets.QLabel("<b>Production Controls</b>"))
        
        self.btn_load = QtWidgets.QPushButton("Load YOLO Model")
        self.btn_load.clicked.connect(self.load_yolo)
        
        self.btn_start = QtWidgets.QPushButton("Start Live Feed")
        self.btn_start.clicked.connect(self.start_camera)
        self.btn_start.setStyleSheet("background:#4CAF50; color:white; font-weight:bold;")
        
        self.btn_stop = QtWidgets.QPushButton("Stop Feed")
        self.btn_stop.clicked.connect(self.stop_camera)
        self.btn_stop.setStyleSheet("background:#E91E63; color:white; font-weight:bold;")

        self.btn_manual_trig = QtWidgets.QPushButton("Manual Trigger")
        self.btn_manual_trig.clicked.connect(self.run_manual_inspection)
        self.btn_manual_trig.setStyleSheet("background:#FF9800; color:white; font-weight:bold;")
        
        for btn in [self.btn_load, self.btn_start, self.btn_stop, self.btn_manual_trig]:
            btn.setFixedHeight(35)
            right_panel.addWidget(btn)

        # Manual Logic Testing (Dataset)
        right_panel.addSpacing(20)
        right_panel.addWidget(QtWidgets.QLabel("<b>Manual Logic Testing</b>"))
        self.btn_browse = QtWidgets.QPushButton("📁 Browse Labeled Folder")
        self.btn_browse.clicked.connect(self.load_dataset_folder)
        right_panel.addWidget(self.btn_browse)

        self.file_list = QtWidgets.QListWidget()
        self.file_list.itemClicked.connect(self.validate_labeled_file)
        right_panel.addWidget(self.file_list)

        right_panel.addStretch()
        main_layout.addLayout(right_panel, 1)

    # ---- FUNCTIONAL ACTIONS ----
    def load_yolo(self):
        file_path, _ = QtWidgets.QFileDialog.getOpenFileName(self, "Select YOLO Model", "", "Weights (*.pt)")
        if file_path:
            try:
                self.model = YOLO(file_path)
                QtWidgets.QMessageBox.information(self, "Success", "YOLO Model Loaded!")
            except Exception as e:
                QtWidgets.QMessageBox.critical(self, "Error", f"Failed to load model: {e}")

    def start_camera(self):
        if not self.thread:
            self.thread = VideoThread()
            self.thread.change_pixmap_signal.connect(self.update_screen)
            self.thread.start()
            self.status_banner.setText("LIVE FEED ACTIVE")

    def stop_camera(self):
        if self.thread:
            self.thread.stop()
            self.thread = None
            self.screen.clear()
            self.status_banner.setText("STOPPED")

    def run_manual_inspection(self):
        """CAPTURES CURRENT LIVE FRAME AND RUNS YOLO + COLOR LOGIC"""
        if self.thread is None or self.thread.current_frame is None:
            QtWidgets.QMessageBox.warning(self, "Error", "Start Live Feed first!")
            return
        
        if self.model is None:
            QtWidgets.QMessageBox.warning(self, "Error", "Load YOLO Model first!")
            return

        frame = self.thread.current_frame.copy()
        results = self.model(frame)[0]
        
        body_lab, deco_lab = None, None
        h, w = frame.shape[:2]

        for box in results.boxes:
            cls = int(box.cls[0])
            x1, y1, x2, y2 = map(int, box.xyxy[0])
            roi = frame[y1:y2, x1:x2]
            
            lab_val = extract_advanced_pigment(roi)
            if cls == 1: body_lab = lab_val # COLOR class
            if cls == 2: deco_lab = lab_val # DECO class
            
            # Draw on UI
            color = (255, 120, 0) if cls == 1 else (0, 200, 255)
            cv2.rectangle(frame, (x1, y1), (x2, y2), color, 3)

        self.process_comparison(body_lab, deco_lab)
        self.update_screen(frame)

    def process_comparison(self, body_lab, deco_lab):
        if body_lab is not None and deco_lab is not None:
            # Ignore L channel for metallic surfaces
            de = np.linalg.norm(body_lab[1:] - deco_lab[1:])
            is_match = de < DELTA_E_THRESHOLD
            status = "PASS" if is_match else "FAIL"
            bg = "#2e7d32" if is_match else "#c62828"
            self.status_banner.setText(f"{status} | ΔE: {de:.2f}")
            self.status_banner.setStyleSheet(f"font-size:38px; font-weight:bold; background:{bg}; color:white;")
            self.add_log(status, de)
        else:
            self.status_banner.setText("OBJECT NOT DETECTED")

    # ---- DATASET TESTING LOGIC ----
    def load_dataset_folder(self):
        path = QtWidgets.QFileDialog.getExistingDirectory(self, "Select Folder")
        if path:
            self.dataset_path = path
            self.file_list.clear()
            self.file_list.addItems([f for f in os.listdir(path) if f.lower().endswith(('.png', '.jpg'))])

    def validate_labeled_file(self, item):
        img_path = os.path.join(self.dataset_path, item.text())
        lbl_path = img_path.rsplit('.', 1)[0] + ".txt"
        img = cv2.imread(img_path)
        if img is None: return

        h, w = img.shape[:2]
        body_lab, deco_lab = None, None

        if os.path.exists(lbl_path):
            with open(lbl_path, 'r') as f:
                for line in f.readlines():
                    cls, x, y, nw, nh = map(float, line.split())
                    x1, y1 = int((x-nw/2)*w), int((y-nh/2)*h)
                    x2, y2 = int((x+nw/2)*w), int((y+nh/2)*h)
                    roi = img[max(0,y1):y2, max(0,x1):x2]
                    val = extract_advanced_pigment(roi)
                    if int(cls) == 1: body_lab = val
                    if int(cls) == 2: deco_lab = val
                    cv2.rectangle(img, (x1,y1), (x2,y2), (0,255,0), 2)

        self.process_comparison(body_lab, deco_lab)
        self.update_screen(img)

    def add_log(self, res, de):
        row = self.log_table.rowCount()
        self.log_table.insertRow(row)
        self.log_table.setItem(row, 1, QtWidgets.QTableWidgetItem(datetime.now().strftime("%H:%M:%S")))
        self.log_table.setItem(row, 2, QtWidgets.QTableWidgetItem(res))
        self.log_table.setItem(row, 3, QtWidgets.QTableWidgetItem(f"{de:.2f}"))

    def update_screen(self, frame):
        rgb = cv2.cvtColor(frame, cv2.COLOR_BGR2RGB)
        h, w, ch = rgb.shape
        qimg = QtGui.QImage(rgb.data, w, h, ch*w, QtGui.QImage.Format_RGB888)
        self.screen.setPixmap(QtGui.QPixmap.fromImage(qimg).scaled(self.screen.size(), QtCore.Qt.KeepAspectRatio))

if __name__ == "__main__":
    app = QtWidgets.QApplication(sys.argv)
    win = DecoInspectionSystem(); win.show()
    sys.exit(app.exec_())
